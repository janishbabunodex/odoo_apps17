<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="report_inventory_fsn_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <div class="page">

                    <!-- Header -->
                    <div class="text-center mb-4">
                        <h2>Inventory FSN Report</h2>
                        <p class="text-muted">
                            Period:
                            <strong><t t-esc="docs.date_start"/></strong>
                            to
                            <strong><t t-esc="docs.date_end"/></strong>
                            |
                            FSN Filter:
                            <strong>
                                <t t-if="docs.fsn_filter == 'all'">All</t>
                                <t t-elif="docs.fsn_filter == 'F'">Fast Moving (F)</t>
                                <t t-elif="docs.fsn_filter == 'S'">Slow Moving (S)</t>
                                <t t-else="">Non Moving (N)</t>
                            </strong>
                        </p>
                    </div>

                    <!-- Data Table -->
                    <table class="table table-sm table-bordered o_main_table">
                        <thead style="background-color:#4B3869; color:#fff;">
                            <tr>
                                <th>#</th>
                                <th>Ref</th>
                                <th>Product</th>
                                <th>Category</th>
                                <th>Location</th>
                                <th class="text-right">Opening</th>
                                <th class="text-right">Closing</th>
                                <th class="text-right">Avg Stock</th>
                                <th class="text-right">Sale Qty</th>
                                <th class="text-right">Turnover</th>
                                <th class="text-center">FSN</th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="report_data" t-as="line">
                                <tr>
                                    <td><t t-esc="line_index + 1"/></td>
                                    <td><t t-esc="line.get('internal_ref') or ''"/></td>
                                    <td><t t-esc="line.get('product_name') or ''"/></td>
                                    <td><t t-esc="line.get('category_name') or ''"/></td>
                                    <td><t t-esc="line.get('location_name') or ''"/></td>
                                    <td class="text-right">
                                        <t t-esc="'%.2f' % (line.get('opening_stock') or 0)"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'%.2f' % (line.get('closing_stock') or 0)"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'%.2f' % (line.get('average_stock') or 0)"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'%.2f' % (line.get('sale_qty') or 0)"/>
                                    </td>
                                    <td class="text-right">
                                        <t t-esc="'%.4f' % (line.get('turnover_ratio') or 0)"/>
                                    </td>
                                    <td class="text-center">
                                        <t t-set="mark" t-value="line.get('mark', 'N')"/>
                                        <span t-if="mark == 'F'"
                                              style="background:#C6EFCE;color:#006100;padding:2px 6px;border-radius:4px;font-weight:bold;">F</span>
                                        <span t-elif="mark == 'S'"
                                              style="background:#FFEB9C;color:#9C6500;padding:2px 6px;border-radius:4px;font-weight:bold;">S</span>
                                        <span t-else=""
                                              style="background:#FFC7CE;color:#9C0006;padding:2px 6px;border-radius:4px;font-weight:bold;">N</span>
                                    </td>
                                </tr>
                            </t>
                            <t t-if="not report_data">
                                <tr>
                                    <td colspan="11" class="text-center text-muted">
                                        No records found for the selected criteria.
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <!-- Legend -->
                    <div class="mt-3">
                        <strong>Legend:</strong>
                        |
                        <span style="background:#C6EFCE;color:#006100;padding:2px 8px;border-radius:4px;font-weight:bold;">F</span>
                        Fast Moving (Turnover &gt; 3)
                        |
                        <span style="background:#FFEB9C;color:#9C6500;padding:2px 8px;border-radius:4px;font-weight:bold;">S</span>
                        Slow Moving (Turnover 1–3)
                        |
                        <span style="background:#FFC7CE;color:#9C0006;padding:2px 8px;border-radius:4px;font-weight:bold;">N</span>
                        Non Moving (Turnover ≤ 1)
                    </div>

                </div>
            </t>
        </t>
    </template>

</odoo>
